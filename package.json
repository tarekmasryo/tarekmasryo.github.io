{
  "name": "tarekmasryo.github.io",
  "type": "module",
  "scripts": {
    "start": "python -m http.server 8000",
    "serve": "python -m http.server 8000",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:prod": "npm audit --omit=dev",
    "validate:static": "node scripts/validate-static.mjs",
    "check": "npm run lint && npm run format:check && npm run validate:static && npm run audit:prod"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "private": true,
  "engines": {
    "node": ">=22"
  }
}
